# ============================================================
#  Perfil Spring
# ============================================================
SPRING_PROFILES_ACTIVE=dev

# ============================================================
#  Banco de dados (Postgres)
# ============================================================
POSTGRES_RINHA_URL=jdbc:postgresql://localhost:5432/rinha
POSTGRES_USERNAME=rinha
POSTGRES_PASSWORD=troque-isso

POSTGRES_DB=rinha
POSTGRES_USER=rinha
POSTGRES_HOST_AUTH_METHOD=scram-sha-256

# ============================================================
#  Seguranca
# ============================================================
JWT_SECRET=troque-isso-em-prod

# Cookies com flag Secure. Em prod (HTTPS): true. Em dev sem HTTPS: false.
APP_COOKIES_SECURE=false

# ============================================================
#  Mercado Pago
# ============================================================
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_TEST_TOKEN=

# ============================================================
#  Imgur
# ============================================================
IMGUR_ACCESS_TOKEN=

# ============================================================
#  Email (Gmail SMTP)
# ============================================================
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=

# ============================================================
#  Frontend
# ============================================================
FRONTEND_URL=http://localhost:3000
